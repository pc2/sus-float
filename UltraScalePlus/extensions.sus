    action accumulate'0 : double to_accumulate'0 {
        to_accumulator = to_accumulate
        to_accumulator_valid = true
    } else {
        to_accumulator_valid = false
    }
    double to_accumulator_direct = LatencyOffset#(OFFSET: FP64_ADD_LATENCY)(to_accumulator)
    bool to_accumulator_valid_direct = LatencyOffset#(OFFSET: FP64_ADD_LATENCY)(to_accumulator_valid)

    // The trick with these delays is that to get a non-last to_accumulator_valid, at least nextPow2#(V: fp64_ADD_LATENCY) cycles must have passed, giving any still in-progress is_last transfers time to clear out of the fp64_add. 
    action last'0: -> double total_result {
        // Implicitly adds parallel registers, to slow down the data flow enough for all previous accumulations to have completed. 
        accumulator_input = to_accumulator
        accumulator_input_valid = to_accumulator_valid
        total_result = accumulator_output
        stored_accumulator = 0.0d // The add happens first, this just resets the stored accumulator such that the next sequence total is 0.0
        is_last = true
    } else {
        accumulator_input = to_accumulator_direct
        accumulator_input_valid = to_accumulator_valid_direct
        is_last = false
    }
}
